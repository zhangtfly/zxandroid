<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/register_ll"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#00000000"
    android:orientation="vertical"
    android:visibility="gone"
    tools:visibility="visible">

    <TextView
        android:id="@+id/register_phone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:text="手机号"
        android:textColor="#333333"
        android:textSize="17dp" />

    <com.hjq.shape.view.ShapeEditText
        android:id="@+id/register_et_phone"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        android:background="@null"
        android:hint="请输入手机号"
        android:inputType="phone"
        android:maxLength="11"
        android:paddingHorizontal="12dp"
        android:singleLine="true"
        android:textColor="#333333"
        android:textSize="15dp"
        app:shape_radius="8dp"
        app:shape_solidColor="@color/white"
        app:shape_strokeColor="#e5e5e5"
        app:shape_strokeSize="0.5dp" />

    <TextView
        android:id="@+id/register_tv_code"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:text="验证码"
        android:textColor="#333333"
        android:textSize="17dp" />

    <com.hjq.shape.layout.ShapeLinearLayout
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        app:shape_radius="8dp"
        app:shape_solidColor="@color/white"
        app:shape_strokeColor="#e5e5e5"
        app:shape_strokeSize="0.5dp">

        <com.hjq.shape.view.ShapeEditText
            android:id="@+id/register_et_code"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="请输入验证码"
            android:inputType="number"
            android:maxLength="6"
            android:paddingHorizontal="12dp"
            android:singleLine="true"
            android:textColor="#333333"
            android:textSize="15dp" />

        <com.example.myapplication.login.view.CountdownView
            android:id="@+id/register_get_code"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_alignParentRight="true"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:text="获取验证码"
            android:textColor="@drawable/countdown_color_selector"
            android:textSize="14dp" />

    </com.hjq.shape.layout.ShapeLinearLayout>

    <TextView
        android:id="@+id/register_tv_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:text="设置密码"
        android:textColor="#333333"
        android:textSize="17dp" />

    <com.hjq.shape.layout.ShapeLinearLayout
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        app:shape_radius="8dp"
        app:shape_solidColor="@color/white"
        app:shape_strokeColor="#e5e5e5"
        app:shape_strokeSize="0.5dp">

        <com.hjq.shape.view.ShapeEditText
            android:id="@+id/register_password"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="请输入6-20位密码"
            android:inputType="textPassword"
            android:maxLength="20"
            android:paddingHorizontal="12dp"
            android:singleLine="true"
            android:textColor="#333333"
            android:textSize="15dp" />

        <ImageView
            android:id="@+id/register_btn_toggle_password"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center_vertical"
            android:padding="10dp"
            android:src="@drawable/password_on_ic" />
    </com.hjq.shape.layout.ShapeLinearLayout>

    <TextView
        android:id="@+id/register_confirm_tv_password"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:text="确认密码"
        android:textColor="#333333"
        android:textSize="17dp" />

    <com.hjq.shape.layout.ShapeLinearLayout
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="8dp"
        app:shape_radius="8dp"
        app:shape_solidColor="@color/white"
        app:shape_strokeColor="#e5e5e5"
        app:shape_strokeSize="0.5dp">

        <com.hjq.shape.view.ShapeEditText
            android:id="@+id/register_confirm_et_password"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="请再次输入密码"
            android:inputType="textPassword"
            android:maxLength="20"
            android:paddingHorizontal="12dp"
            android:singleLine="true"
            android:textColor="#333333"
            android:textSize="15dp" />

        <ImageView
            android:id="@+id/register_confirm_btn_toggle_password"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center_vertical"
            android:padding="10dp"
            android:src="@drawable/password_on_ic" />
    </com.hjq.shape.layout.ShapeLinearLayout>

    <com.google.android.flexbox.FlexboxLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="3dp"
        android:layout_marginRight="20dp"
        app:alignItems="center"
        app:flexWrap="wrap">

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/check_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:scaleX="0.9"
            android:scaleY="0.9"
            android:text="我已阅读并同意"
            android:textColor="#333333"
            android:textSize="13dp"
            app:boxBackgroundColor="@color/checkbox_color_selector"
            app:buttonTint="@color/checkbox_color_selector" />

        <TextView
            android:id="@+id/user_agreement"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:text="《用户服务协议》"
            android:textColor="#4ea8ca"
            android:textSize="12dp" />

        <TextView
            android:id="@+id/user_policy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="2dp"
            android:text="《隐私政策》"
            android:textColor="#4ea8ca"
            android:textSize="12dp" />

    </com.google.android.flexbox.FlexboxLayout>

    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/submit_register"
        android:layout_width="match_parent"
        android:layout_height="49dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="注册"
        android:textColor="@color/white"
        app:shape_radius="8dp"
        app:shape_solidColor="#4ea8ca"
        app:shape_solidPressedColor="#93c9db" />

    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/submit_forget"
        android:layout_width="match_parent"
        android:layout_height="49dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="确定"
        android:textColor="@color/white"
        app:shape_radius="8dp"
        app:shape_solidColor="#4ea8ca"
        app:shape_solidPressedColor="#93c9db" />
</LinearLayout>