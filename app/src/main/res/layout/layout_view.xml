<?xml version="1.0" encoding="utf-8"?>
<com.hjq.shape.layout.ShapeLinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:id="@+id/login_ll"
    android:layout_height="wrap_content"
    android:background="#00000000"
    android:visibility="gone"
    xmlns:tools="http://schemas.android.com/tools"
    tools:visibility="visible"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginHorizontal="20dp"
        android:orientation="horizontal">

        <com.hjq.shape.view.ShapeTextView
            android:id="@+id/account_login"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="账号登录"
            android:textColor="@color/white"
            android:textSize="15dp"
            app:shape_radiusInBottomLeft="10dp"
            app:shape_radiusInTopLeft="10dp"
            app:shape_solidColor="#93c9db"
            app:shape_solidSelectedColor="#4ea8ca" />

        <com.hjq.shape.view.ShapeTextView
            android:id="@+id/code_login"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="验证码登录"
            android:textColor="@color/white"
            android:textSize="15dp"
            app:shape_radiusInBottomRight="10dp"
            app:shape_radiusInTopRight="10dp"
            app:shape_solidColor="#f2c488"
            app:shape_solidSelectedColor="#eca040" />
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <LinearLayout
            android:id="@+id/code_login_rl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_phone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:text="手机号"
                android:textColor="#333333"
                android:textSize="17dp" />

            <com.hjq.shape.view.ShapeEditText
                android:id="@+id/ed_phone"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:background="@null"
                android:hint="请输入手机号"
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:textColor="#333333"
                android:textSize="15dp"
                app:shape_radius="8dp"
                android:maxLength="11"
                android:inputType="phone"
                app:shape_solidColor="@color/white"
                app:shape_strokeColor="#e5e5e5"
                app:shape_strokeSize="0.5dp" />

            <TextView
                android:id="@+id/tv_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:text="验证码"
                android:textColor="#333333"
                android:textSize="17dp" />

            <com.hjq.shape.layout.ShapeLinearLayout
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                app:shape_radius="8dp"
                app:shape_solidColor="@color/white"
                app:shape_strokeColor="#e5e5e5"
                app:shape_strokeSize="0.5dp">

                <com.hjq.shape.view.ShapeEditText
                    android:id="@+id/et_code"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="请输入验证码"
                    android:maxLength="6"
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:inputType="number"
                    android:textColor="#333333"
                    android:textSize="15dp" />

                <com.example.myapplication.login.view.CountdownView
                    android:id="@+id/login_get_code"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_alignParentRight="true"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="12dp"
                    android:text="获取验证码"
                    android:textColor="@drawable/countdown_color_selector"
                    android:textSize="14dp" />
            </com.hjq.shape.layout.ShapeLinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/phone_login_rl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_account"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:text="用户名"
                android:textColor="#333333"
                android:textSize="17dp" />

            <com.hjq.shape.view.ShapeEditText
                android:id="@+id/et_account"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                android:background="@null"
                android:hint="请输入用户名"
                android:paddingHorizontal="12dp"
                android:singleLine="true"
                android:textColor="#333333"
                android:textSize="15dp"
                android:inputType="textVisiblePassword"
                app:shape_radius="8dp"
                app:shape_solidColor="@color/white"
                app:shape_strokeColor="#e5e5e5"
                app:shape_strokeSize="0.5dp" />

            <TextView
                android:id="@+id/tv_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                android:text="密码"
                android:textColor="#333333"
                android:textSize="17dp" />

            <com.hjq.shape.layout.ShapeLinearLayout
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                app:shape_radius="8dp"
                app:shape_solidColor="@color/white"
                app:shape_strokeColor="#e5e5e5"
                app:shape_strokeSize="0.5dp">

                <com.hjq.shape.view.ShapeEditText
                    android:id="@+id/et_password"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="请输入密码"
                    android:maxLength="20"
                    android:inputType="textPassword"
                    android:paddingHorizontal="12dp"
                    android:singleLine="true"
                    android:textColor="#333333"
                    android:textSize="15dp" />

                <ImageView
                    android:id="@+id/btn_toggle_password"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center_vertical"
                    android:padding="10dp"
                    android:src="@drawable/password_on_ic" />
            </com.hjq.shape.layout.ShapeLinearLayout>
        </LinearLayout>


    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="15dp"
        android:layout_marginTop="3dp"
        android:layout_marginRight="20dp">

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/remember_me"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="记住我"
            android:textSize="13dp"
            android:scaleX="0.9"
            android:scaleY="0.9"
            android:textColor="#333333"
            app:boxBackgroundColor="@color/checkbox_color_selector"
            app:buttonTint="@color/checkbox_color_selector" />

        <TextView
            android:id="@+id/forget_password"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:text="忘记密码？"
            android:textColor="#4ea8ca"
            android:textSize="15dp" />
    </RelativeLayout>

    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/submit_login"
        android:layout_width="match_parent"
        android:layout_height="49dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="登录"
        android:textColor="@color/white"
        app:shape_radius="8dp"
        app:shape_solidColor="#4ea8ca"
        app:shape_solidPressedColor="#93c9db" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#e5e5e5" />

        <TextView
            android:id="@+id/tv_or"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:text="或"
            android:textColor="#333333"
            android:textSize="15dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"
            android:background="#e5e5e5" />
    </LinearLayout>

    <com.hjq.shape.view.ShapeTextView
        android:id="@+id/visitor_login"
        android:layout_width="match_parent"
        android:layout_height="49dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="👤  游客访问"
        android:textColor="#333333"
        android:textStyle="italic"
        app:shape_radius="8dp"
        app:shape_solidColor="#e5e5e5"
        app:shape_solidPressedColor="#50e5e5e5" />

    <TextView
        android:id="@+id/visitor_tip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:text="游客每天可使用5次"
        android:textColor="#666666"
        android:textSize="12dp" />
</com.hjq.shape.layout.ShapeLinearLayout>